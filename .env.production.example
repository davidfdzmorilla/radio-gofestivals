# =============================================================================
# radio.gofestivals · .env.production.example
# =============================================================================
# NO commitear .env.production. Este archivo es una plantilla — copiar a
# .env.production en el VPS y rellenar los secretos con valores reales.
#
#   cp .env.production.example .env.production
#   # editar .env.production con: openssl rand -base64 24  (passwords)
#   #                           : openssl rand -hex 32     (JWT_SECRET)
#
# ROTAR POSTGRES_PASSWORD, REDIS_PASSWORD y JWT_SECRET antes del primer
# deploy. El validador de app/core/config.py rechaza placeholders tipo
# "change_me" en staging/prod.
# =============================================================================

# --- Host y dominio -----------------------------------------------------------
DOMAIN=radio.gofestivals.eu
GIT_SHA=latest

# --- Entorno ------------------------------------------------------------------
ENV=staging
LOG_LEVEL=INFO

# --- Secretos (ROTAR ANTES DEL PRIMER DEPLOY) --------------------------------
POSTGRES_PASSWORD=REPLACE_WITH_openssl_rand_base64_24
REDIS_PASSWORD=REPLACE_WITH_openssl_rand_base64_24
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32_CHARS_MIN_32

# --- Postgres -----------------------------------------------------------------
POSTGRES_DB=radio
POSTGRES_USER=radio
DATABASE_URL=postgresql+asyncpg://radio:${POSTGRES_PASSWORD}@postgres:5432/radio

# --- Redis --------------------------------------------------------------------
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# --- JWT ----------------------------------------------------------------------
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Radio-Browser ------------------------------------------------------------
RB_USER_AGENT=radio.gofestivals/1.0 (admin@gofestivals.eu)
RB_SYNC_TIMEOUT=30
RB_SYNC_TAG_LIMIT=500

# --- Health check de stations -------------------------------------------------
HEALTH_CHECK_INTERVAL=21600
HEALTH_CHECK_TIMEOUT=5
HEALTH_CHECK_MAX_FAILURES=3

# --- ICY worker ---------------------------------------------------------------
ICY_ONDEMAND_CONCURRENCY=40
ICY_AMBIENT_CONCURRENCY=10
ICY_AMBIENT_POLL_INTERVAL=60
ICY_AMBIENT_TOP_N=50

# --- CORS ---------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://radio.gofestivals.eu

# --- Integración gofestivals (read-only cross-DB) — opcional -----------------
GOFESTIVALS_DB_URL=
GOFESTIVALS_CACHE_TTL=3600

# --- Observabilidad — opcional -----------------------------------------------
PROMETHEUS_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.1
