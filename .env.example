# =============================================================================
# radio.gofestivals · .env.example
# =============================================================================
# Copia este archivo a .env y rellena los valores.
#
#   $ cp .env.example .env
#
# CRÍTICO: .env está en .gitignore. No commitear secrets.
# Si falta cualquier variable crítica, el backend falla en el arranque
# con un mensaje explícito.
# =============================================================================


# -----------------------------------------------------------------------------
# ENTORNO
# -----------------------------------------------------------------------------
ENV=dev                    # dev | staging | prod
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR


# -----------------------------------------------------------------------------
# POSTGRES
# -----------------------------------------------------------------------------
POSTGRES_DB=radio
POSTGRES_USER=radio
POSTGRES_PASSWORD=radio_dev_password   # ← rotar en prod

# URL que usa la app. DOS contextos a tener en cuenta:
#   · Dentro de la red docker (servicios api, icy-worker): host=postgres puerto=5432
#   · Desde el host macOS/Linux (pytest, psql, DBeaver):   host=localhost puerto=5433
# El 5433 evita colisión con postgres de brew que suele ocupar :5432 en el host.
#
# Por defecto este valor es el del contexto docker. Para trabajar desde el host,
# copia el bloque en un .env.local (gitignored) con:
#   DATABASE_URL=postgresql+asyncpg://radio:radio_dev_password@localhost:5433/radio
DATABASE_URL=postgresql+asyncpg://radio:radio_dev_password@postgres:5432/radio


# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=60         # segundos para caché de endpoints "baratos"
REDIS_GENRES_TTL=300       # el árbol de géneros cambia poco


# -----------------------------------------------------------------------------
# JWT (admin login)
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_prod_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440    # 24h


# -----------------------------------------------------------------------------
# RADIO-BROWSER
# -----------------------------------------------------------------------------
# Radio-Browser pide user-agent identificable para debugging por su lado.
# Formato sugerido: <app>/<version> (<contacto>)
RB_USER_AGENT=radio.gofestivals/0.1 (admin@gofestivals.eu)
RB_SYNC_TIMEOUT=30         # segundos
RB_SYNC_TAG_LIMIT=500      # max estaciones por tag


# -----------------------------------------------------------------------------
# HEALTH-CHECK
# -----------------------------------------------------------------------------
HEALTH_CHECK_INTERVAL=21600   # segundos entre checks (6h)
HEALTH_CHECK_TIMEOUT=5        # timeout HEAD request
HEALTH_CHECK_MAX_FAILURES=3   # fallos consecutivos para marcar broken


# -----------------------------------------------------------------------------
# ICY WORKER (now-playing)
# -----------------------------------------------------------------------------
ICY_AMBIENT_POLL_INTERVAL=60      # segundos entre polls ambient
ICY_AMBIENT_TOP_N=50              # top N estaciones para polling constante
ICY_ONDEMAND_TIMEOUT=300          # segundos sin subscribers antes de cerrar worker

# Semaphores independientes para que una avalancha on-demand no
# deje sin slots al polling ambient (y viceversa).
ICY_ONDEMAND_CONCURRENCY=40
ICY_AMBIENT_CONCURRENCY=10
# ICY_CONCURRENCY=...  # DEPRECATED: si se define, se usa como ondemand con warning


# -----------------------------------------------------------------------------
# FRONTEND (se inyectan como NEXT_PUBLIC_*)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=radio.gofestivals


# -----------------------------------------------------------------------------
# CROSS-DB (vínculo con gofestivals)
# -----------------------------------------------------------------------------
# Conexión READ-ONLY a la DB de gofestivals para resolver festival_id → datos.
# En fase 1 se puede dejar vacío y mostrar solo IDs.
GOFESTIVALS_DB_URL=
GOFESTIVALS_CACHE_TTL=3600   # cachear agresivo, los festivales cambian poco


# -----------------------------------------------------------------------------
# OBSERVABILIDAD (opcional)
# -----------------------------------------------------------------------------
PROMETHEUS_ENABLED=false
TELEGRAM_ALERT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=


# -----------------------------------------------------------------------------
# SENTRY (opcional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=dev
SENTRY_TRACES_SAMPLE_RATE=0.1
